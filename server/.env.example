# Spotify (obrigatório para playlists Spotify — lista faixas e BPM/key grátis)
# Crie um app em https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=seu_client_id
SPOTIFY_CLIENT_SECRET=seu_client_secret

# YouTube (obrigatório para playlists YouTube — só lista os vídeos; BPM/key vêm como padrão)
# Ative YouTube Data API v3 em https://console.cloud.google.com/ (cota gratuita)
YOUTUBE_API_KEY=sua_chave_youtube

# Porta do servidor (opcional)
# PORT=3000
